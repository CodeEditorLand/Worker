{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "./",
		"outDir": "Target",
		"rootDir": "Source",
		"lib": ["DOM", "ESNext", "WebWorker"],
		"target": "ESNext",
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"noEmit": true
	},
	"extends": "@playform/build/tsconfig",
	"include": ["Source", "@types/serviceworker"],
	"exclude": ["Target"]
}
