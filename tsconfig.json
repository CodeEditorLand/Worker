{
	"$schema": "https://json.schemastore.org/tsconfig",

	"compilerOptions": {
		"baseUrl": "./",

		"composite": true,

		"declarationMap": true,

		"emitDeclarationOnly": true,

		"lib": ["DOM", "ESNext", "WebWorker"],

		"module": "ESNext",

		"moduleResolution": "Bundler",

		"outDir": "Target",

		"rootDir": "Source",

		"target": "ESNext"
	},

	"exclude": ["Target"],

	"extends": "@playform/build/tsconfig",

	"include": ["Source", "@types/serviceworker"]
}
