{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "./",
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"lib": [
			"DOM",
			"ESNext",
			"WebWorker"
		],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"outDir": "Target",
		"rootDir": "./Source",
		"target": "ESNext"
	},
	"exclude": [
		"Target",
		"node_modules"
	],
	"extends": "@playform/build/tsconfig",
	"include": [
		"Source",
		"@types/serviceworker"
	]
}
